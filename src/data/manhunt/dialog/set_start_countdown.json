{
    "type": "minecraft:multi_action",
    "inputs": [
        {
            "label": "开始活动前的Hunter禁止活动时间",
            "key": "var",
            "type": "text"
        },
        {
            "label": "开始活动前的Hunter禁止活动时间",
            "start": 0.0,
            "end": 300.0,
            "step": 0.05,
            "initial": 30.0,
            "width": 600,
            "key": "var_",
            "type": "number_range"
        }
    ],
    "title": "设置开始活动前的Hunter禁止活动时间 单位: 秒",
    "actions": [
        {
            "label": "保存文本输入框的内容",
            "tooltip": "点击设置",
            "action": {
                "type": "dynamic/run_command",
                "template": "function manhunt:options/countdown_set_second {var: $(var)}"
            }
        },
        {
            "label": "保存数字输入的内容",
            "tooltip": "点击设置",
            "action": {
                "type": "dynamic/run_command",
                "template": "function manhunt:options/countdown_set_second {var: $(var_)}"
            }
        }
    ],
    "can_close_with_escape": true
}